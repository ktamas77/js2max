{
  "name": "js2max",
  "version": "0.1.0",
  "description": "Compile JavaScript files into Max for Live (.amxd) devices",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "js2max": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/ examples/",
    "format:check": "prettier --check src/ tests/ examples/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "max",
    "msp",
    "max-for-live",
    "ableton",
    "cycling74",
    "maxpat",
    "v8",
    "compiler"
  ],
  "author": "Tamas Kalman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ktamas77/js2max.git"
  },
  "homepage": "https://github.com/ktamas77/js2max",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "acorn": "^8.14.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
